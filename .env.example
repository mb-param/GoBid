#
# Tender platform — copy to tender-platform/.env (and optionally tender-platform/src/.env)
#

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/tender_intelligence


# Redis / BullMQ — REDIS_URL only (TLS → rediss://)
# If unset in process env, code defaults to redis://127.0.0.1:6379
# Plaintext example:
REDIS_URL=redis://127.0.0.1:6379
# Remote example (do not commit real secrets): REDIS_URL=redis://:password@host.example:6390
#
# Encrypted .env (dotenvx): `npm install` includes @dotenvx/dotenvx — env.js decrypts automatically
# when DOTENV_PRIVATE_KEY is set or a local `.env.keys` file exists (never commit `.env.keys`).

# Crawler ergonomics (Playwright/Crawlee)
HEADLESS=true
MAX_BROWSER_CONCURRENCY=4
REQUEST_TIMEOUT_SECS=120
MAX_REQUEST_RETRIES=3
USE_CRAWLEE_FINGERPRINTS=false

# Browserless / remote Chromium — WebSocket URLs
# BROWSERLESS_WS_ENDPOINT=wss://chrome.browserless.io?token=
# CHROME_WS_ENDPOINT=wss://...   # alternate name read by env.js


# Scheduling (Bull repeatable metadata — quote cron expression in POSIX shells)



PORTAL_REPEAT_CRON=


# API
API_PORT=3800
RELAX_HEALTH_MONGO=0

# Operator console ↔ API (SSE + mutations)
CONTROL_PLANE_ORIGIN=http://127.0.0.1:3000
# When set, protects /automation/* (use same value in NEXT_PUBLIC_OPS_API_TOKEN on the frontend)
OPS_API_TOKEN=


# Portals toggles — 0/disabled skips registry entry logic
ENABLE_PORTAL_SAMGOV=1
ENABLE_PORTAL_BONFIRE=0
ENABLE_PORTAL_SOUTHAFRICA=1
ENABLE_PORTAL_KENYA=1
ENABLE_PORTAL_BIDNET=0
ENABLE_PORTAL_GOVTRIBE=0
ENABLE_PORTAL_NIGERIA=0
ENABLE_PORTAL_ETHIOPIA=0

# ── URLs — crawl seeds, interactive login targets, remote browser WS (unset/empty ⇒ code default).
# References: src/core/portalRegistry.js, src/portals/*/login.js.

# Crawl seed — must be a *.sam.gov opportunities URL (never Login.gov / secure.login.gov).
SAMGOV_SEARCH_URL=https://sam.gov/search/?index=opp&page=1&pageSize=25&sort=-modifiedDate
# Headed login bootstrap (SAM.gov content login landing).
SAMGOV_LOGIN_URL=https://sam.gov/content/login

# Bonfire — official global host; crawler seed defaults to `{BASE}/welcome` unless BONFIRE_START_PATH is set.
BONFIRE_BASE_URL=https://global.bonfirehub.com
# Relative to BASE_URL only when you override the crawl start (optional).
BONFIRE_START_PATH=
# Interactive login path fragment (headed bootstrap); full URL is built from BASE + this.
BONFIRE_LOGIN_PATH=/welcome

# South Africa National Treasury eTenders (official).
ZA_ETENDERS_URL=https://www.etenders.gov.za/Home/opportunities?status=Advertised&PagingLength=50
ZA_ETENDERS_LOGIN_URL=https://www.etenders.gov.za/Home/

# Kenya — public tenders list seed + Treasury supplier portal for interactive login (official).
KENYA_TENDER_LIST_URL=https://www.treasury.go.ke/tenders/
KENYA_LOGIN_URL=https://supplier.treasury.go.ke/
# Alternate alias read by kenya/login.js only; leave unset if redundant.
KENYA_SUPPLIER_LOGIN_URL=

BIDNET_LOGIN_URL=https://www.bidnetdirect.com/
BIDNET_ENTRY_URL=
GOVTRIBE_LOGIN_URL=https://govtribe.com/

NIGERIA_LOGIN_URL=https://www.tenders.gov.ng/
NIGERIA_PORTAL_ENTRY=

ETHIOPIA_LOGIN_URL=https://supplier.egp.gov.et/
ETHIOPIA_ENTRY_URL=

BULLMQ_WORKER_CONCURRENCY=3
