#
# Tender platform — copy to tender-platform/.env (and optionally tender-platform/src/.env)
#

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/tender_intelligence


# Redis / BullMQ — REDIS_URL only (TLS → rediss://)
# If unset in process env, code defaults to redis://127.0.0.1:6379
# Plaintext example:
REDIS_URL=redis://:SADFWwerty12345opi@43.205.217.221:6390
# Remote example (do not commit real secrets): REDIS_URL=redis://:password@host.example:6390
#
# Encrypted .env (dotenvx): `npm install` includes @dotenvx/dotenvx — env.js decrypts automatically
# when DOTENV_PRIVATE_KEY is set or a local `.env.keys` file exists (never commit `.env.keys`).

# Crawler ergonomics (Playwright/Crawlee)
HEADLESS=true
MAX_BROWSER_CONCURRENCY=4
REQUEST_TIMEOUT_SECS=120
MAX_REQUEST_RETRIES=3
USE_CRAWLEE_FINGERPRINTS=false

# Browserless / remote Chromium (optional)
# BROWSERLESS_WS_ENDPOINT=wss://chrome.browserless.io?token=





# Scheduling (Bull repeatable metadata — quote cron expression in POSIX shells)



PORTAL_REPEAT_CRON=


# API
API_PORT=3800
RELAX_HEALTH_MONGO=0

# Operator console ↔ API (SSE + mutations)
CONTROL_PLANE_ORIGIN=http://127.0.0.1:3000
# When set, protects /automation/* (use same value in NEXT_PUBLIC_OPS_API_TOKEN on the frontend)
OPS_API_TOKEN=


# Browserless / remote Chromium — WebSocket URLs (optional)


# BROWSERLESS_WS_ENDPOINT=wss://chrome.browserless.io?token=

# CHROME_WS_ENDPOINT=wss://...    # alternate name read by env.js
ENABLE_PORTAL_NIGERIA=0
ENABLE_PORTAL_ETHIOPIA=0

# Seeds / tenant URLs — see src/core/portalRegistry.js for defaults
SAMGOV_SEARCH_URL=https://secure.login.gov/
BONFIRE_BASE_URL=https://global.bonfirehub.com/portal/?tab=myOpportunities

BULLMQ_WORKER_CONCURRENCY=3
